{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leoflow.io/schemas/leoflow.yaml/v1.0",
  "title": "Leoflow Project Configuration",
  "description": "Developer-facing configuration. Consumed by 'leoflow compile' to build a container image and generate dag.json.",
  "type": "object",
  "required": ["dag_id"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0",
      "default": "1.0"
    },
    "dag_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_][a-zA-Z0-9_-]{0,199}$"
    },
    "description": { "type": "string" },
    "owner": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },

    "python_version": {
      "type": "string",
      "enum": ["3.10", "3.11", "3.12"],
      "default": "3.11"
    },
    "base_image": {
      "type": "string",
      "description": "Override the default leoflow/python-runtime base image."
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Python package specifiers, e.g., 'pandas==2.1.0'."
    },
    "system_packages": {
      "type": "array",
      "items": { "type": "string" },
      "description": "OS packages to install via apt-get."
    },

    "dag_source": {
      "type": "string",
      "default": "dag.py",
      "description": "Path to the DAG definition file relative to leoflow.yaml."
    },
    "include_paths": {
      "type": "array",
      "items": { "type": "string" },
      "default": ["."],
      "description": "Files and directories to copy into the image."
    },
    "exclude_paths": {
      "type": "array",
      "items": { "type": "string" },
      "default": [".git", "__pycache__", "*.pyc", ".venv", "venv"]
    },

    "build": {
      "type": "object",
      "properties": {
        "dockerfile": {
          "type": "string",
          "description": "Path to a custom Dockerfile. If set, autogeneration is skipped."
        },
        "context": {
          "type": "string",
          "default": ".",
          "description": "Build context directory."
        },
        "platforms": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["linux/amd64"]
        },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },

    "registry": {
      "type": "object",
      "properties": {
        "url": { "type": "string", "description": "e.g., 'ghcr.io/myorg', 'docker.io/myorg'." },
        "auth_method": {
          "type": "string",
          "enum": ["docker_config", "env", "iam"],
          "default": "docker_config"
        },
        "image_name": { "type": "string", "description": "Defaults to dag_id." },
        "tag_strategy": {
          "type": "string",
          "enum": ["version", "git_sha", "git_tag", "custom"],
          "default": "version"
        }
      }
    },

    "defaults": {
      "type": "object",
      "properties": {
        "retries": { "type": "integer", "minimum": 0 },
        "retry_delay_seconds": { "type": "integer", "minimum": 0 },
        "execution_timeout_seconds": { "type": "integer", "minimum": 1 },
        "resources": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        }
      }
    },
    "staging": {
      "type": "object",
      "description": "Opt-in per-DAG-run shared RWX volume mounted at /staging (ADR 0022).",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "size": { "type": "string", "description": "Kubernetes quantity, e.g. 5Gi." },
        "storage_class": { "type": "string", "description": "RWX StorageClass; empty = cluster default." }
      },
      "additionalProperties": false
    },

    "tasks": {
      "type": "object",
      "description": "Per-task overrides bound by task_id (ADR 0023). Each key MUST match a task_id in the compiled DAG; an unknown id fails the compile. A set field overrides the value compiled from the DAG (task override > DAG defaults).",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "retries": { "type": "integer", "minimum": 0 },
          "retry_delay_seconds": { "type": "integer", "minimum": 0 },
          "execution_timeout_seconds": { "type": "integer", "minimum": 1 },
          "env": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "Environment variables merged over the task's compiled env."
          },
          "resources": {
            "type": "object",
            "properties": {
              "requests": {
                "type": "object",
                "properties": {
                  "cpu": { "type": "string" },
                  "memory": { "type": "string" }
                },
                "additionalProperties": false
              },
              "limits": {
                "type": "object",
                "properties": {
                  "cpu": { "type": "string" },
                  "memory": { "type": "string" }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          "execution": {
            "type": "object",
            "properties": {
              "node_selector": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "tolerations": { "type": "array" },
              "service_account": { "type": "string" },
              "image_pull_policy": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  }
}
