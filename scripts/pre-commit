#!/usr/bin/env bash
# Leoflow pre-commit hook (ADR 0011 + 0012).
# Blocks the commit when formatting, vetting, or linting fail, or when total
# test coverage drops by more than 1% from the recorded baseline.
set -euo pipefail

echo "[pre-commit] gofmt"
unformatted=$(gofmt -l $(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true) 2>/dev/null || true)
if [ -n "$unformatted" ]; then
	echo "::error:: the following files are not gofmt-clean:"
	echo "$unformatted"
	echo "run 'make fmt'"
	exit 1
fi

echo "[pre-commit] go vet"
go vet ./...

echo "[pre-commit] golangci-lint"
golangci-lint run ./...

echo "[pre-commit] test + coverage gate"
profile=$(mktemp)
filtered=$(mktemp)
go test -coverprofile="$profile" ./... >/dev/null
# Exclude from the unit-coverage floor (ADR 0011): generated code, main
# packages, version, and the thin DB/lock-binding files that are exercised by
# integration tests (//go:build integration) rather than unit tests.
exclude='(/internal/storage/queries/|/internal/storage/repository\.go:|/internal/storage/postgres\.go:|/internal/storage/redis\.go:|/internal/storage/scheduler_store\.go:|/internal/storage/agent_store\.go:|/internal/scheduler/leader\.go:|\.pb\.go:|/internal/version/|/cmd/)'
grep -vE "$exclude" "$profile" >"$filtered"
current=$(go tool cover -func="$filtered" | tail -1 | awk '{print $3}' | tr -d '%')
rm -f "$profile" "$filtered"

baseline_file=".git/coverage-baseline"
baseline=$(cat "$baseline_file" 2>/dev/null || echo "0")
echo "  total coverage: ${current}% (baseline ${baseline}%)"
if awk -v c="$current" -v b="$baseline" 'BEGIN { exit !(b - c > 1.0) }'; then
	echo "::error:: coverage dropped from ${baseline}% to ${current}% (>1%); add tests (ADR 0011)"
	exit 1
fi
echo "$current" >"$baseline_file"

echo "[pre-commit] ok"
