#!/usr/bin/env bash
# Leoflow pre-commit hook (ADR 0011 + 0012).
# Blocks the commit when formatting, vetting, or linting fail, or when filtered
# unit-test coverage is below the floor. The floor is the SAME fixed threshold
# the CI enforces — a moving baseline would let coverage ratchet downward locally
# and only fail in CI (which is exactly what happened once).
set -euo pipefail

# Coverage floor (percent). Keep in sync with .github/workflows/ci.yaml.
COVERAGE_FLOOR=75

echo "[pre-commit] gofmt"
unformatted=$(gofmt -l $(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true) 2>/dev/null || true)
if [ -n "$unformatted" ]; then
	echo "::error:: the following files are not gofmt-clean:"
	echo "$unformatted"
	echo "run 'make fmt'"
	exit 1
fi

echo "[pre-commit] go vet"
go vet ./...

echo "[pre-commit] golangci-lint"
golangci-lint run ./...

# Python lint for the parser + runtime — the CI "Python parser tests" job runs
# `ruff check`, so gate it locally too (each subdir has its own pyproject /
# excludes). Best-effort: skip with a note if ruff is not installed.
echo "[pre-commit] ruff (parser + runtime)"
if command -v ruff >/dev/null 2>&1; then
	ruff check parser runtime/python
else
	echo "  ruff not found; skipping (CI enforces it) — 'pip install ruff' to gate locally"
fi

echo "[pre-commit] test + coverage gate"
profile=$(mktemp)
filtered=$(mktemp)
go test -coverprofile="$profile" ./... >/dev/null
# Exclude from the unit-coverage floor (ADR 0011): generated code, main
# packages, version, and the thin DB/lock-binding files that are exercised by
# integration tests (//go:build integration) rather than unit tests.
exclude='(/internal/storage/queries/|/internal/storage/repository\.go:|/internal/storage/postgres\.go:|/internal/storage/redis\.go:|/internal/storage/scheduler_store\.go:|/internal/storage/agent_store\.go:|/internal/storage/xcom_index\.go:|/internal/xcom/redis_backend\.go:|/internal/logs/tail\.go:|/internal/scheduler/leader\.go:|\.pb\.go:|/internal/version/|/cmd/)'
grep -vE "$exclude" "$profile" >"$filtered"
current=$(go tool cover -func="$filtered" | tail -1 | awk '{print $3}' | tr -d '%')
rm -f "$profile" "$filtered"

echo "  filtered coverage: ${current}% (floor ${COVERAGE_FLOOR}%)"
if awk -v c="$current" -v f="$COVERAGE_FLOOR" 'BEGIN { exit !(c < f) }'; then
	echo "::error:: coverage ${current}% is below floor ${COVERAGE_FLOOR}% (ADR 0011); add tests"
	exit 1
fi

echo "[pre-commit] ok"
